# Cursor Cloud Agent VNC desktop — asset download configuration
# Used by config.sh and cloud-agent-setup sync-assets.
#
# URL pattern: ${CLOUD_AGENT_ASSETS_DOWNLOAD_BASE_URL}/${sha256}${suffix}
# Example logo: .../4961e33371b2d4ab16aef6058906f3462b140664aa277897f3d65f0681c28119.svg

CLOUD_AGENT_ASSETS_DOWNLOAD_BASE_URL=https://public-asphr-vm-daemon-bucket.s3.us-east-1.amazonaws.com/cloud-agent-assets

# offline = vendor/cloud-agent-assets only (default, no network)
# online  = cloud-agent-setup sync-assets from CDN above
# auto    = offline if vendor complete, else online
ASSET_INSTALL_MODE=offline

# Passed to cloud-agent-setup sync-assets (sha256 of prerequisite package list)
CLOUD_AGENT_ASSET_PREREQUISITES_VERSION=0de57c12c7a85aa580c3ff54edcc7ab34b5178a573784753ef8d3a20fb27f2c8

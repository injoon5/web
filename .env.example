# --- Local development ---

# Convex deployment URL (set by `npx convex dev`)
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Admin dashboard password. Set the same value in Convex via:
#   npx convex env set ADMIN_SECRET "<same value>"
ADMIN_SECRET=your-secure-admin-password

# Secret pepper for HMAC-SHA256 IP hashing (server-side only).
# Changing this invalidates existing ipHash values in the database.
# Also set in Convex (same value): npx convex env set IP_HASH_SECRET "<same value>"
IP_HASH_SECRET=your-ip-hash-pepper

# --- Vercel (set in the project's Environment Variables, not in this file) ---
#
# CONVEX_DEPLOY_KEY    Production deploy key from the Convex dashboard.
#                      Required by `npx convex deploy` during the build.
#                      The deploy command sets PUBLIC_CONVEX_URL automatically,
#                      so you do NOT need to set PUBLIC_CONVEX_URL on Vercel.
#
# ADMIN_SECRET         Same value as locally. Must match the Convex env
#                      (`npx convex env set ADMIN_SECRET ... --prod`).
#
# IP_HASH_SECRET       Required for Vite build (imported via $env/static/private).
#                      Must be set on Vercel Production and Preview.

{
	"buildCommand": "npx convex deploy --cmd 'npx turbo run build-image-cache apply-optimized-images build'",
	"redirects": [
		{
			"source": "/.well-known/webfinger",
			"destination": "https://mastodon.injoon5.com/.well-known/webfinger",
			"permanent": true
		},
		{
			"source": "/internal/rss.xml",
			"destination": "/rss.xml",
			"permanent": true
		}
	],
	"headers": [
		{
			"source": "/.well-known/webfinger",
			"headers": [
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				}
			]
		},
		{
			"source": "/images/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=604800, s-maxage=2592000, stale-while-revalidate=86400"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/relay-oij225/static/(.*)",
			"destination": "https://us-assets.i.posthog.com/static/$1"
		},
		{
			"source": "/relay-oij225/(.*)",
			"destination": "https://us.i.posthog.com/$1"
		}
	]
}

{
	"$schema": "https://turbo.build/schema.json",
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"UPSTASH_REDIS_REST_URL",
		"UPSTASH_REDIS_REST_TOKEN",
		"ADMIN_SECRET",
		"CONVEX_DEPLOY_KEY",
		"IP_HASH_SECRET",
		"PUBLIC_CONVEX_URL"
	],
	"tasks": {
		"fingerprint-images": {
			"inputs": [
				"scripts/fingerprint-images.mjs",
				"static/**/*.jpg",
				"static/**/*.jpeg",
				"static/**/*.png",
				"static/**/*.webp"
			],
			"outputs": [".cache/source-fingerprints.json"]
		},
		"build-image-cache": {
			"dependsOn": ["fingerprint-images"],
			"inputs": [".cache/source-fingerprints.json", "scripts/optimize-images.mjs"],
			"outputs": [".cache/image-optimize.json", ".cache/image-mirror/**"],
			"env": [
				"IMAGE_MAX_WIDTH",
				"IMAGE_MAX_HEIGHT",
				"JPEG_QUALITY",
				"PNG_COMPRESSION",
				"WEBP_QUALITY"
			]
		},
		"apply-optimized-images": {
			"dependsOn": ["build-image-cache"],
			"cache": false
		},
		"build": {
			"dependsOn": ["apply-optimized-images"],
			"outputs": [".svelte-kit/**", ".vercel/**"],
			"env": ["PUBLIC_CONVEX_URL", "ADMIN_SECRET", "CONVEX_DEPLOY_KEY", "IP_HASH_SECRET"]
		}
	}
}
